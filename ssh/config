Host *
  # IPv4 only for speed
  AddressFamily inet
  Compression yes
  ControlMaster auto
  ControlPath /tmp/ssh_mux_%h_%p_%r
  ControlPersist 10m
  # send a keep-alive after 30s of inactivity
  ServerAliveInterval 30

Host freenas-local
  HostName 192.168.1.208
  User conor
  Port 22
  UserKnownHostsFile /dev/null
  StrictHostKeyChecking no
  PasswordAuthentication no
  IdentitiesOnly yes
  LogLevel FATAL
  ForwardAgent yes

Host freenas
  HostName 100.85.23.25
  User conor
  Port 22
  UserKnownHostsFile /dev/null
  StrictHostKeyChecking no
  PasswordAuthentication no
  IdentitiesOnly yes
